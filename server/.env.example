# Copy to .env and fill in. Never commit the filled-in file.
# These same keys must exist in the Render service's Environment settings.

# --- Required: the server exits at boot without these ---
MONGO_URI=
JWT_SECRET=            # >= 32 chars

# --- Required in any real deploy ---
# Every emailed link and both Stripe redirect URLs are built from this.
# No trailing slash. In production this is the deployed front-end origin.
CLIENT_URL=http://localhost:3000
PORT=5000

# --- Email (Resend). Unset means no mail is sent at all. ---
RESEND_API_KEY=
# Must be a domain verified in Resend. Unset falls back to Resend's sandbox
# sender, which only delivers to the account owner.
MAIL_FROM=

# --- Stripe. Unset key means billing routes return 503. ---
# A restricted key (rk_) is enough: Checkout, Billing and Customer Portal.
STRIPE_SECRET_KEY=
# Without this, checkout takes payment and access is never granted. In live
# mode create the endpoint in the Dashboard against the deployed URL and
# subscribe it to customer.subscription.* and checkout.session.completed.
STRIPE_WEBHOOK_SECRET=

# Price IDs, not Product IDs. Test and live are separate worlds — these do not
# carry over between them.
STRIPE_PRICE_STARTER_MONTH=
STRIPE_PRICE_STARTER_YEAR=
STRIPE_PRICE_PRO_MONTH=
STRIPE_PRICE_PRO_YEAR=
STRIPE_PRICE_ENTERPRISE_MONTH=
STRIPE_PRICE_ENTERPRISE_YEAR=
